# ── Base de données ──────────────────────────────────────────────
# PostgreSQL. Valeurs par défaut du docker-compose.yml en local (port 5433).
DATABASE_URL=postgresql://tcg_user:tcg_password@127.0.0.1:5433/tcg_matchmaking

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=
ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_SECRET=
REFRESH_TOKEN_EXPIRY=7d

# ── Firebase Admin (notifications push FCM) ──────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── Cloudinary (upload des avatars) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── OAuth (optionnel) ────────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# ── Serveur ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Seed (prisma/seed.js) ────────────────────────────────────────
# Mot de passe attribué aux comptes de démo créés par le seed.
# Requis pour lancer `npm run prisma:seed`.
SEED_PASSWORD=
